<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 应用基本信息 -->
    <key>CFBundleDevelopmentRegion</key>
    <string>zh_CN</string>
    
    <key>CFBundleDisplayName</key>
    <string>星轨人生</string>
    
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    
    <key>CFBundleName</key>
    <string>星轨人生</string>
    
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    
    <key>CFBundleShortVersionString</key>
    <string>2.1.0</string>
    
    <key>CFBundleVersion</key>
    <string>21</string>
    
    <key>LSMinimumSystemVersion</key>
    <string>10.15</string>
    
    <key>NSHighResolutionCapable</key>
    <true/>
    
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2024-2026 星轨人生. All rights reserved.</string>
    
    <!-- 技术支持链接 - 修复审核问题 -->
    <key>CFBundleHelpBookName</key>
    <string>星轨人生帮助</string>
    
    <!-- 技术支持 URL (GitHub Pages) -->
    <key>SupportURL</key>
    <string>https://732642856.github.io/star-track-life/docs/support/</string>
    
    <!-- 应用图标 -->
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    
    <!-- 支持的语言 -->
    <key>CFBundleLocalizations</key>
    <array>
        <string>zh_CN</string>
        <string>zh_TW</string>
        <string>en</string>
    </array>
    
    <!-- 应用类别 -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.lifestyle</string>
    
    <!-- 深色模式支持 -->
    <key>NSRequiresAquaSystemAppearance</key>
    <false/>
    
    <!-- 文件类型支持 -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>StarTrack Character</string>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>LSHandlerRank</key>
            <string>Owner</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.startracklife.character</string>
            </array>
            <key>CFBundleTypeIconFile</key>
            <string>document-icon</string>
        </dict>
    </array>
    
    <!-- 导出UTI类型 -->
    <key>UTExportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeDescription</key>
            <string>星轨人生角色文件</string>
            <key>UTTypeIdentifier</key>
            <string>com.startracklife.character</string>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>stchar</string>
                </array>
                <key>public.mime-type</key>
                <array>
                    <string>application/json</string>
                </array>
            </dict>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.json</string>
                <string>public.text</string>
            </array>
        </dict>
    </array>
    
    <!-- URL Scheme 支持 -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>星轨人生</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>startracklife</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
